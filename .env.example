# Copy to .env for local use, or set these in your host's dashboard.
#
# Local MySQL (default): leave as is.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=givetime
DB_SSL=false
#
# Cloud MySQL (e.g. TiDB Cloud Serverless): use the values from the
# provider's "Connect" panel, and set DB_SSL=true. Example shape:
#   DB_HOST=gateway01.<region>.prod.aws.tidbcloud.com
#   DB_PORT=4000
#   DB_USER=xxxxxxxx.root
#   DB_PASSWORD=your_password
#   DB_NAME=givetime
#   DB_SSL=true
